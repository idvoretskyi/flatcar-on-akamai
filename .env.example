# ----------------------------------------------------------------------------
# flatcar-on-akamai — deployment environment
#
# Copy to `.env` and edit. `.env` is git-ignored. Every script and the
# Makefile source these values. Nothing here is secret EXCEPT LINODE_TOKEN,
# which you should prefer to export in your shell rather than commit anywhere.
# ----------------------------------------------------------------------------

# --- Linode API token (scopes: Linodes RW, Images RW) -----------------------
# Prefer exporting this in your shell instead of storing it here.
# export LINODE_TOKEN=...
LINODE_TOKEN=""

# --- Flatcar image ----------------------------------------------------------
# Release channel: stable | beta | alpha
CHANNEL="stable"
# Architecture (only amd64 is covered by this repo today).
ARCH="amd64"

# --- Linode placement -------------------------------------------------------
# Region for both the uploaded image and the instance. `linode-cli regions list`
REGION="us-ord"
# Instance type. `linode-cli linodes types`
# g6-nanode-1  (1GB RAM, ~$5/mo)  — bare Flatcar, no Kubernetes
# g6-standard-1 (2GB RAM, ~$12/mo) — minimum comfortable size for k3s
INSTANCE_TYPE="g6-standard-1"
# Instance + image label prefix.
LABEL="flatcar"

# --- Identity (delivered via Ignition, NOT Linode ssh_keys) -----------------
# Your SSH public key. Afterburn on Akamai cannot consume Linode-managed keys,
# so the key MUST travel inside the Ignition config. Required.
SSH_AUTHORIZED_KEY=""
# Hostname applied via Ignition. NODE_HOSTNAME is used instead of the generic
# HOSTNAME to avoid silently inheriting the Bash built-in $HOSTNAME variable.
NODE_HOSTNAME="flatcar-akamai"

# --- Image id (filled in after `make image`) --------------------------------
# Example: private/1234567
IMAGE_ID=""

# --- Ignition generation ----------------------------------------------------
# Generator backend: knuckle | butane
#   knuckle = build the patched fork and run `--emit-ignition` (needs Go)
#   butane  = compile butane/flatcar.bu with the standalone butane binary
BACKEND="knuckle"

# Patched knuckle fork used by the knuckle backend.
KNUCKLE_REPO="https://github.com/idvoretskyi/knuckle.git"
KNUCKLE_REF="emit-ignition"

# Pinned standalone butane release used by the butane backend.
# The default value is defined in scripts/lib/versions.sh; set here to
# override it for all scripts and CI.
BUTANE_VERSION="v0.23.0"

# --- Kubernetes cluster overlay ---------------------------------------------
# CLUSTER=none  : pure Flatcar node (default)
# CLUSTER=k3s   : layer k3s (single-node server) on top of Flatcar via
#                 Ignition overlay (see butane/k8s/k3s-server.bu)
CLUSTER="none"

# Shared cluster token. If unset, scripts/render-ignition.sh generates one
# automatically with `openssl rand -hex 32` and appends it here.
# Do not share or commit this value.
K3S_TOKEN=""
